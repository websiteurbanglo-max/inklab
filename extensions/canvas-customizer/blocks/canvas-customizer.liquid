{{ 'canvas-customizer.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign canvas_size    = block.settings.canvas_size
  assign show_fonts     = block.settings.show_font_selector
  assign show_upload    = block.settings.show_image_upload
  assign placeholder    = block.settings.placeholder_text | default: 'Enter your text here...'
  assign is_enabled     = false
  for tag in product.tags
    if tag == 'inkcanvas'
      assign is_enabled = true
      break
    endif
  endfor
-%}

{%- if is_enabled -%}

<div
  id="inkcanvas-root-{{ block.id }}"
  class="inkcanvas-root"
  {{ block.shopify_attributes }}
  data-block-id="{{ block.id }}"
  data-shop="{{ shop.myshopify_domain }}"
  data-product-id="{{ product.id }}"
  data-canvas-size="{{ canvas_size }}"
  data-show-fonts="{{ show_fonts }}"
  data-show-upload="{{ show_upload }}"
  data-placeholder="{{ placeholder | escape }}"
>
  {%- comment -%} Trigger button shown on product page {%- endcomment -%}
  <button id="ikc-open-btn-{{ block.id }}" class="ikc-trigger-btn" type="button">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
    Customize Product
  </button>

  {%- comment -%} Preview area — shown after user saves design {%- endcomment -%}
  <div id="ikc-preview-{{ block.id }}" class="ikc-preview-area" style="display:none">
    <p class="ikc-preview-label">Your design preview:</p>
    <img id="ikc-preview-img-{{ block.id }}" class="ikc-preview-img" src="" alt="Your custom design" />
    <button id="ikc-edit-btn-{{ block.id }}" class="ikc-edit-btn" type="button">Edit design</button>
  </div>

  {%- comment -%} Modal overlay + popup {%- endcomment -%}
  <div id="ikc-modal-{{ block.id }}" class="ikc-modal-overlay" aria-hidden="true">
    <div class="ikc-modal" role="dialog" aria-modal="true" aria-label="Customize your product">
      <div class="ikc-modal-header">
        <h2 class="ikc-modal-title">Customize Your Product</h2>
        <button id="ikc-close-btn-{{ block.id }}" class="ikc-close-btn" type="button" aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <div class="ikc-modal-body">
        {%- comment -%} Variant selector inside popup {%- endcomment -%}
        <div class="ikc-group" id="ikc-variant-group-{{ block.id }}">
          <label class="ikc-label" for="ikc-variant-select-{{ block.id }}">Select size / variant</label>
          <select id="ikc-variant-select-{{ block.id }}" class="ikc-select">
            {%- for variant in product.variants -%}
              <option value="{{ variant.id }}" data-title="{{ variant.title | escape }}">
                {{ variant.title }}
              </option>
            {%- endfor -%}
          </select>
        </div>

        <p id="ikc-modal-error-{{ block.id }}" class="ikc-error-msg" style="display:none"></p>

        <div class="ikc-editor-wrap">
          {%- comment -%} Canvas column {%- endcomment -%}
          <div class="ikc-canvas-col">
            <canvas id="ikc-canvas-{{ block.id }}"></canvas>
          </div>

          {%- comment -%} Controls column {%- endcomment -%}
          <div class="ikc-controls-col">
            <div class="ikc-group">
              <label class="ikc-label" for="ikc-text-input-{{ block.id }}">Your text</label>
              <input id="ikc-text-input-{{ block.id }}" class="ikc-input" type="text"
                placeholder="{{ placeholder | escape }}" maxlength="80" />
            </div>

            <div class="ikc-group">
              <label class="ikc-label" for="ikc-color-input-{{ block.id }}">Text color</label>
              <div class="ikc-color-row">
                <input id="ikc-color-input-{{ block.id }}" class="ikc-color-swatch" type="color" value="#1a1a1a" />
                <span id="ikc-color-hex-{{ block.id }}" class="ikc-color-hex">#1a1a1a</span>
              </div>
            </div>

            {%- if show_fonts -%}
            <div class="ikc-group">
              <label class="ikc-label" for="ikc-font-select-{{ block.id }}">Font style</label>
              <select id="ikc-font-select-{{ block.id }}" class="ikc-select">
                <option value="">Loading fonts…</option>
              </select>
            </div>
            {%- endif -%}

            {%- if show_upload -%}
            <div class="ikc-group">
              <label class="ikc-label">Upload image</label>
              <label class="ikc-upload-btn" for="ikc-img-input-{{ block.id }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <span id="ikc-upload-label-{{ block.id }}">Choose image (PNG / JPG)</span>
              </label>
              <input id="ikc-img-input-{{ block.id }}" type="file" accept="image/png,image/jpeg,image/webp" style="display:none" />
            </div>
            {%- endif -%}

            <p class="ikc-note">Preview updates live. Design is printed in high resolution.</p>
          </div>
        </div>
      </div>

      <div class="ikc-modal-footer">
        <button id="ikc-save-btn-{{ block.id }}" class="ikc-save-btn" type="button">Save Design</button>
        <button id="ikc-cancel-btn-{{ block.id }}" class="ikc-cancel-btn" type="button">Cancel</button>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    var blockId = '{{ block.id }}';
    window.InkCanvasConfig = window.InkCanvasConfig || {};
    window.InkCanvasConfig[blockId] = {
      blockId:    blockId,
      appUrl:     'https://inklab-production.up.railway.app',
      proxyBase:  '/apps/inkcanvas',
      shop:       {{ shop.myshopify_domain | json }},
      productId:  '{{ product.id }}',
      canvasSize: {{ canvas_size }},
      showFonts:  {{ show_fonts }},
      showUpload: {{ show_upload }},
      placeholder: {{ placeholder | json }},
    };
  })();
</script>

<script src="{{ 'fabric.min.js' | asset_url }}" defer></script>
<script src="{{ 'canvas-customizer.js' | asset_url }}" defer></script>

{%- endif -%}

{% schema %}
{
  "name": "Canvas Customizer",
  "target": "section",
  "settings": [
    {
      "type": "range",
      "id": "canvas_size",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Canvas size",
      "default": 500
    },
    {
      "type": "checkbox",
      "id": "show_font_selector",
      "label": "Show font selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_image_upload",
      "label": "Allow image upload",
      "default": true
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Text input placeholder",
      "default": "Enter your text here..."
    }
  ]
}
{% endschema %}
